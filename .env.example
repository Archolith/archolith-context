# =============================================================================
# archolith-proxy — Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your setup.
# All values have defaults — only UPSTREAM_API_KEY is required to start.
#
# The proxy is a drop-in replacement for api.openai.com. Point any
# OpenAI-compatible client at localhost:9800 and it just works.
# =============================================================================

# ----- Upstream API (required) -----------------------------------------------
# The LLM API to proxy requests to. Any OpenAI-compatible endpoint works.
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=                     # REQUIRED — your OpenAI (or compatible) API key

# ----- Extraction Model ------------------------------------------------------
# A cheaper model used to extract facts from conversations.
# Defaults to gpt-4.1-mini via OpenAI. Can point to any OpenAI-compatible endpoint.
EXTRACTOR_BASE_URL=https://api.openai.com/v1
EXTRACTOR_API_KEY=                    # Defaults to UPSTREAM_API_KEY if empty
EXTRACTOR_MODEL=gpt-4.1-mini

# ----- Embeddings ------------------------------------------------------------
# Used for semantic similarity scoring during context assembly.
# Defaults to OpenAI text-embedding-3-small.
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=                    # Defaults to EXTRACTOR_API_KEY if empty
EMBEDDING_MODEL=text-embedding-3-small

# ----- Graph Backend ---------------------------------------------------------
# Choose "ladybug" (embedded, zero infrastructure) or "neo4j" (requires server).
# LadybugDB is recommended for getting started — no external dependencies.
GRAPH_BACKEND=ladybug

# LadybugDB settings (only used when GRAPH_BACKEND=ladybug)
LADYBUG_DB_PATH=./data/context.lbug
LADYBUG_MAX_CONCURRENT=8

# Neo4j settings (only used when GRAPH_BACKEND=neo4j)
SESSION_NEO4J_URI=bolt://localhost:7687
SESSION_NEO4J_DATABASE=neo4j
SESSION_NEO4J_USER=neo4j
SESSION_NEO4J_PASSWORD=              # REQUIRED when using Neo4j backend

# ----- Proxy Behavior --------------------------------------------------------
PROXY_PORT=9800                       # Port the proxy listens on

# Context assembly — how much history to compress and how
COHERENCE_TAIL_SIZE=10                # Recent messages preserved verbatim
MAX_TAIL_MESSAGES=20                  # Max expansion for tool-call coherence
CONTEXT_TOKEN_BUDGET=15000            # Token budget for assembled context
SESSION_TTL_HOURS=24                  # Hours before session data expires

# Cold start — how many turns before graph assembly kicks in
COLD_START_TURNS=3
COLD_START_TOKEN_THRESHOLD=20000

# Savings gate — only rewrite when it saves meaningful tokens
ASSEMBLY_MIN_SAVINGS_RATIO=0.20       # Skip if savings < 20%
ASSEMBLY_MIN_INPUT_TOKENS=50000       # Don't rewrite below 50K input tokens

# ----- Feature Flags ---------------------------------------------------------
# Enable one or more advanced features. All default to off.
EMBEDDING_ENABLED=false               # Semantic similarity in retrieval
COMPACTION_ENABLED=false              # Overflow compaction when budget exceeded
QUERY_REWRITE_ENABLED=false           # Rewrite ambiguous queries before embedding
SESSION_RECALL_TOOL_ENABLED=false     # Inject recall tool so model can query its graph
RTK_ENABLED=false                     # Filter outbound tool-role messages with archolith_rtk

# ----- Resilience ------------------------------------------------------------
UPSTREAM_MAX_RETRIES=3
UPSTREAM_RETRY_BACKOFF_BASE_S=0.5
NEO4J_MAX_RETRIES=3
NEO4J_RETRY_BACKOFF_BASE_S=1.0
ASSEMBLY_LATENCY_BUDGET_MS=150        # Fall back to passthrough if exceeded

# ----- Long-Term Memory (optional) -------------------------------------------
# Promote session facts to durable cross-session memory.
# Requires a memory backend (archolith-memory, mem0, zep, etc.).
PROMOTION_ENABLED=false
MEMORY_API_URL=http://localhost:8200
MEMORY_API_KEY=
MEMORY_ENGINES_JSON=                  # JSON array of engine configs (see docs)
PROMOTION_MIN_CONFIDENCE=0.9
PROMOTION_DRY_RUN=false

# ----- Admin -----------------------------------------------------------------
# Token for protecting operator endpoints (/sessions, /metrics, etc.).
# When empty, endpoints are open (safe for localhost-only use).
ADMIN_TOKEN=

# ----- Benchmark -------------------------------------------------------------
# Models for harness_benchmark.py (provider/modelID format for opencode.json)
BENCHMARK_PROXY_MODEL=deepseek-proxy/deepseek-v4-flash
BENCHMARK_DIRECT_MODEL=deepseek-direct/deepseek-v4-flash
# Model for session_explorer.py (bare API model string)
BENCHMARK_MODEL=deepseek-v4-flash
